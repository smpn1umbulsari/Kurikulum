{
  "name": "architect",
  "description": "Software Architect - can read all, write to architecture docs",
  "permissions": {
    "read": [
      "**/*"
    ],
    "write": [
      "docs/architecture/**",
      "docs/**/*.md",
      "src/**"
    ],
    "deny": [
      ".env",
      "**/secrets/**",
      "**/credentials/**"
    ]
  }
}