{
  "name": "SIKAD v4.0 & AETHER Workspace",
  "version": "1.2.0",
  "ignoredPaths": [
    "node_modules",
    ".git",
    "*.zip",
    "final boss.md"
  ],
  "agentProfiles": [
    {
      "id": "architect",
      "role": "Software Architect",
      "model": "claude-opus-4-8",
      "provider": "anthropic",
      "capabilities": ["architecture", "design", "review", "prd-analysis"],
      "priority": 1,
      "maxConcurrentTasks": 2,
      "fallbackPriority": 1
    },
    {
      "id": "db_architect",
      "role": "Database Architect",
      "model": "claude-sonnet-4-6",
      "provider": "anthropic",
      "capabilities": ["schema", "migration", "optimization", "indexing", "partitioning"],
      "priority": 1,
      "maxConcurrentTasks": 2,
      "fallbackPriority": 2
    },
    {
      "id": "backend",
      "role": "Backend Lead",
      "model": "claude-sonnet-4-6",
      "provider": "anthropic",
      "capabilities": ["api", "backend", "supabase", "edge-functions", "rlpolicies"],
      "priority": 2,
      "maxConcurrentTasks": 3,
      "fallbackPriority": 2
    },
    {
      "id": "frontend",
      "role": "Frontend Lead",
      "model": "gpt-4o",
      "provider": "openai",
      "capabilities": ["react", "ui", "zustand", "typescript", "tailwindcss", "components"],
      "priority": 2,
      "maxConcurrentTasks": 3,
      "fallbackPriority": 3
    },
    {
      "id": "security",
      "role": "Security Architect",
      "model": "claude-sonnet-4-6",
      "provider": "anthropic",
      "capabilities": ["security", "rls", "audit", "encryption", "compliance", "vulnerability"],
      "priority": 1,
      "maxConcurrentTasks": 1,
      "fallbackPriority": 2
    },
    {
      "id": "qa",
      "role": "QA Architect",
      "model": "gpt-4o",
      "provider": "openai",
      "capabilities": ["testing", "quality", "verification", "e2e", "unit-tests", "integration"],
      "priority": 3,
      "maxConcurrentTasks": 3,
      "fallbackPriority": 3
    },
    {
      "id": "devops",
      "role": "DevOps Engineer",
      "model": "gemini-2.5-flash",
      "provider": "google",
      "capabilities": ["deployment", "ci-cd", "infrastructure", "docker", "monitoring", "rollback"],
      "priority": 3,
      "maxConcurrentTasks": 2,
      "fallbackPriority": 4
    }
  ],
  "fallbackChains": {
    "default": ["architect", "backend", "frontend", "qa"],
    "architecture": ["architect", "db_architect", "backend", "qa"],
    "database": ["db_architect", "backend", "architect", "qa"],
    "api": ["backend", "architect", "frontend", "qa"],
    "frontend": ["frontend", "backend", "architect", "qa"],
    "security": ["security", "architect", "backend", "qa"],
    "testing": ["qa", "backend", "architect", "frontend"],
    "deployment": ["devops", "backend", "architect", "qa"],
    "documentation": ["architect", "backend", "frontend", "qa"],
    "review": ["architect", "qa", "backend", "frontend"],
    "migration": ["db_architect", "backend", "architect", "qa"],
    "performance": ["backend", "db_architect", "architect", "devops"]
  },
  "workflowConfig": {
    "maxParallelTasks": 4,
    "taskTimeoutMs": 600000,
    "retryAttempts": 3,
    "retryDelayMs": 5000,
    "enableFallback": true,
    "fallbackConfig": {
      "maxRetriesPerAgent": 3,
      "retryDelayMs": 2000,
      "fallbackTimeoutMs": 120000,
      "enableCascade": true
    }
  },
  "lockTimeoutMs": 300000,
  "testCommand": "npm run aether:test",
  "lintCommand": "npm run aether:lint",
  "eventConfig": {
    "maxHistorySize": 1000,
    "enableLogging": true,
    "logLevel": "info"
  },
  "prdConfig": {
    "autoEnforce": true,
    "requireGapReport": true,
    "blockOnMismatch": false
  },
  "providerConfig": {
    "anthropic": {
      "baseUrl": "https://gateway.olagon.site/anthropic",
      "models": ["claude-opus-4-8", "claude-sonnet-4-6"],
      "enabled": true
    },
    "openai": {
      "baseUrl": "https://api.openai.com/v1",
      "models": ["gpt-4o", "gpt-4o-mini", "gpt-4-turbo"],
      "enabled": false
    },
    "google": {
      "baseUrl": "https://generativelanguage.googleapis.com/v1beta",
      "models": ["gemini-2.5-flash", "gemini-2.5-pro", "gemini-1.5-pro"],
      "enabled": false
    },
    "mistral": {
      "baseUrl": "https://api.mistral.ai/v1",
      "models": ["mistral-large", "mistral-medium", "mistral-small"],
      "enabled": false
    }
  }
}
