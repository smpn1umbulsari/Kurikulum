{
  "name": "aether-kurikulum",
  "version": "0.1.0",
  "description": "AETHER School Management System - Kurikulum management plugin for Indonesian schools",
  "author": "SIKAD Agent",
  "homepage": "https://github.com/sikad-agent/aether-kurikulum",
  "repository": {
    "type": "git",
    "url": "https://github.com/sikad-agent/aether-kurikulum.git"
  },
  "keywords": [
    "claude-code",
    "school-management",
    "kurikulum",
    "indonesia",
    "education",
    "rapor",
    "academic"
  ],
  "license": "MIT",
  "engines": {
    "claude-code": ">=1.0.0"
  },
  "entry": "src/index.ts",
  "manifest": "plugin.json",
  "commands": [
    {
      "name": "kurikulum:setup",
      "description": "Initialize AETHER Kurikulum school management system"
    },
    {
      "name": "kurikulum:student",
      "description": "Manage student records (siswa)"
    },
    {
      "name": "kurikulum:teacher",
      "description": "Manage teacher records (guru)"
    },
    {
      "name": "kurikulum:class",
      "description": "Manage class assignments (kelas)"
    },
    {
      "name": "kurikulum:report",
      "description": "Generate academic reports (rapor)"
    },
    {
      "name": "kurikulum:assessment",
      "description": "Manage assessments and exams"
    }
  ]
}
